{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HiveMind OS",
  "version": "0.1.9",
  "identifier": "com.hivemind.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HiveMind OS",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:*; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "entitlements": "./entitlements.mac.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY4NUQyRTg5RUY1NzMyRjYKUldUMk1sZnZpUzVkYUpHSzdRczF0dVpKb2JZODVIRjBtMSt1ZHVvUXh1R2VmR3hGb3k1YlpmU2MK",
      "endpoints": [
        "https://github.com/hivemind-os/hivemind/releases/latest/download/latest.json"
      ]
    }
  }
}
